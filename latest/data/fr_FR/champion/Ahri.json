t }} {{ abilityresourcename }}"}],"passive":{"name":"Vol essentiel","description":"Après avoir tué 9 sbires ou monstres, Ahri récupère des PV.<br>Après avoir participé à l'élimination d'un champion ennemi, Ahri récupère encore plus de PV.","image":{"full":"Ahri_SoulEater2.png","sprite":"passive0.png","group":"passive","x":48,"y":0,"w":48,"h":48}},"recommended":[]}}}