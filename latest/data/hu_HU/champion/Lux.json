 {{ abilityresourcename }}","maxammo":"-1","range":[3340,3340,3340],"rangeBurn":"3340","image":{"full":"LuxR.png","sprite":"spell8.png","group":"spell","x":240,"y":0,"w":48,"h":48},"resource":"{{ cost }} {{ abilityresourcename }}"}],"passive":{"name":"Megvilágítás","description":"Lux támadó varázslatai néhány másodpercre energiával töltik fel az áldozatot. Lux következő támadása begyújtja az energiát, (Lux szintjétől függő mértékű) bónusz varázssebzést okozva ezzel a célpontnak.","image":{"full":"LuxIlluminatingFraulein.png","sprite":"passive2.png","group":"passive","x":288,"y":48,"w":48,"h":48}},"recommended":[]}}}