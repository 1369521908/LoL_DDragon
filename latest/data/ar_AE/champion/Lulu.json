ngeBurn":"900","image":{"full":"LuluR.png","sprite":"spell8.png","group":"spell","x":48,"y":0,"w":48,"h":48},"resource":"{{ cost }} {{ abilityresourcename }}"}],"passive":{"name":"بيكس، رفيق من الجن","description":"يطلق بيكس صواعق سحرية من الطاقة كلما هاجم البطل الذي يتبعه وحدة معادية أخرى. تكون هذه الصواعق موجهة، ولكن يمكن اعتراضها عبر الوحدات الأخرى.","image":{"full":"Lulu_PixFaerieCompanion.png","sprite":"passive2.png","group":"passive","x":240,"y":48,"w":48,"h":48}},"recommended":[]}}}