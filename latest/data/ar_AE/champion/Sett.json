بقوة وسرعة أكبر بشكل طفيف. كما يكره سيت الخسارة، فيكسب سيت تجدد صحة إضافيًا حسب مقدار صحته الناقصة.","image":{"full":"Sett_P.png","sprite":"passive3.png","group":"passive","x":384,"y":96,"w":48,"h":48}},"recommended":[]}}}