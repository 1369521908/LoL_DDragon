300/450/600","20","15","25","0","0","0","0","0"],"vars":[],"costType":"Tanpa Biaya","maxammo":"-1","range":[200,200,200],"rangeBurn":"200","image":{"full":"RivenFengShuiEngine.png","sprite":"spell11.png","group":"spell","x":240,"y":96,"w":48,"h":48},"resource":"Tanpa Biaya"}],"passive":{"name":"Runic Blade","description":"Ability Riven mengisi charge pedangnya dan basic attack-nya mengonsumsi charge untuk menghasilkan damage tambahan.","image":{"full":"RivenRunicBlades.png","sprite":"passive3.png","group":"passive","x":48,"y":96,"w":48,"h":48}},"recommended":[]}}}