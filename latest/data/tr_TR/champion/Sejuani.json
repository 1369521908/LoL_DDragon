 totaldamagetooltip }} Büyü Hasarı</magicDamage> alır.{{ spellmodifierdescriptionappend }}","leveltip":{"label":["En Az Hasar","En Fazla Hasar","Bekleme Süresi"],"effect":["{{ e1 }} -> {{ e1NL }}","{{ e7 }} -> {{ e7NL }}","{{ cooldown }} -> {{ cooldownNL }}"]},"maxrank":3,"cooldown":[120,105,90],"cooldownBurn":"120/105/90","cost":[100,100,100],"costBurn":"100","datavalues":{},"effect":[null,[125,150,175],[1,1,1],[2,2,2],[80,80,80],[1,1,1],[1.5,1.5,1.5],[200,300,400],[30,30,30],[0,0,0],[0,0,0]],"effectBurn":[null,"125/150/175","1","2","80","1","1.5","200/300/400","30","0","0"],"vars":[],"costType":" {{ abilityresourcename }}","maxammo":"-1","range":[1300,1300,1300],"rangeBurn":"1300","image":{"full":"SejuaniR.png","sprite":"spell12.png","group":"spell","x":48,"y":0,"w":48,"h":48},"resource":"{{ cost }} {{ abilityresourcename }}"}],"passive":{"name":"Kuzeyin Hiddeti","description":"Sejuani çatışmadan çıktıktan sonra ona zırh ve büyü direncinin yanı sıra yavaşlatma etkilerine karşı bağışıklık sağlayan Buz Zırh kazanır. Buz Zırh, Sejuani hasar aldıktan sonra kısa bir süreliğine daha devam eder. Sejuani, sersemlemiş bir rakibe hasar vererek onu parçalayabilir ve hedefin büyük miktarda büyü hasarı almasını sağlar.","image":{"full":"Sejuani_passive.png","sprite":"passive3.png","group":"passive","x":240,"y":96,"w":48,"h":48}},"recommended":[]}}}