[null,"100/150/200","300/450/600","20","15","25","0","0","0","0","0"],"vars":[],"costType":"Bedelsiz","maxammo":"-1","range":[200,200,200],"rangeBurn":"200","image":{"full":"RivenFengShuiEngine.png","sprite":"spell11.png","group":"spell","x":240,"y":96,"w":48,"h":48},"resource":"Bedelsiz"}],"passive":{"name":"Rünlü Kılıç","description":"Riven'ın yetenekleri, kılıcı için yükler biriktirir. Şampiyonun normal saldırıları yükleri tüketerek fazladan hasar verir.","image":{"full":"RivenRunicBlades.png","sprite":"passive3.png","group":"passive","x":48,"y":96,"w":48,"h":48}},"recommended":[]}}}